# ============================================================
# Nirvana System — environment template
# Copy to ~/.env and edit values to fit your machine.
# Every variable below has a sensible default (see paths.js / paths.sh)
# so you only need to set the ones you want to override.
# ============================================================

# --- Root directory (every other path defaults to a child of this) ---
# NIRVANA_HOME=$HOME

# --- Path defaults (NIRVANA_HOME-derived; uncomment to override) ---
# SQUADS_DIR=$NIRVANA_HOME/squads
# SQUADS_LEGACY_DIR=$NIRVANA_HOME/squads-legacy-v4
# BUSINESSES_DIR=$NIRVANA_HOME/businesses
# BUSINESSES_LIBRARY=$NIRVANA_HOME/businesses/_library
# DNA_LIBRARY=$NIRVANA_HOME/businesses/_library/dna
# HARNESS_LOGS_DIR=$NIRVANA_HOME/.harness-logs
# MAESTRO_LOGS_DIR=$NIRVANA_HOME/.maestro-logs
# BUSINESSES_REGISTRY_PATH=$NIRVANA_HOME/.businesses-registry.json
# SQUADS_REGISTRY_PATH=$NIRVANA_HOME/.squads-registry.json
# MAESTRO_DIR=$SQUADS_DIR/business-nirvana-maestro
# PROJECTS_OUTPUT_DIR=.projects-outputs

# --- Harness budget caps (override config.yaml when set) ---
HARNESS_DEFAULT_MAX_COST_USD=50
HARNESS_DEFAULT_MAX_TOKENS=1000000
HARNESS_DEFAULT_MAX_HANDOFFS=100
HARNESS_DEFAULT_MAX_DURATION_SECONDS=7200
HARNESS_ON_BUDGET_EXCEEDED=warn
HARNESS_AUTO_INVOKE_BUDGET_USD=25

# --- Harness routing thresholds ---
HARNESS_MATCH_HIGH_THRESHOLD=0.80
HARNESS_MATCH_AMBIGUOUS_THRESHOLD=0.60
HARNESS_STAGE0_KEYWORD_THRESHOLD=0.5
HARNESS_STAGE_MINUS_1_ENABLED=true
HARNESS_TELEMETRY=jsonl

# --- Maestro execution ---
MAESTRO_DEFAULT_CONCURRENCY=10
MAESTRO_WAVE_TIMEOUT_SECONDS=7200
MAESTRO_FAILURE_RECOVERY=search_alternative_or_create

# --- Maestro DNA Council ---
MAESTRO_DNA_COUNCIL_ADVISOR_COUNT=8
MAESTRO_DNA_PER_ADVISOR_MAX_WORDS=2000
MAESTRO_DNA_VERDICT_PASS_THRESHOLD=0.75
MAESTRO_DNA_VERDICT_REVISE_THRESHOLD=0.50

# --- Maestro Research ---
MAESTRO_RESEARCH_MAX_QUERIES=15
MAESTRO_RESEARCH_MAX_FETCHES=8
MAESTRO_RESEARCH_MAX_SYNTHESIS_WORDS=5000

# --- Maestro Hard Fail Mode (enforcement) ---
MAESTRO_HARD_FAIL_MODE=true
MAESTRO_REQUIRE_SKILL_DISPATCH=true
MAESTRO_DISALLOW_INLINE_HTML=true
MAESTRO_DISALLOW_INLINE_CSS=true
MAESTRO_DISALLOW_INLINE_JS=true
MAESTRO_VALIDATE_HANDOFF_SCHEMA=true
MAESTRO_REJECT_PRAGMATIC_DECISIONS=true
MAESTRO_MIN_OUTPUT_THRESHOLD=1.0
MAESTRO_MAX_REDISPATCH_ROUNDS=3
MAESTRO_REQUIRE_AUTHORSHIP_COMMENT=true

# --- Maestro Synthesizer ---
MAESTRO_SYNTHESIZER_MIN_WORDS=3000
MAESTRO_SYNTHESIZER_MAX_WORDS=8000
MAESTRO_BRAND_BIBLE_MIN_WORDS=40000

# --- Regras de roteamento por runtime (USE_*, linguagem natural) ---
# Diga em qual CLI cada tipo de tarefa roda. Doc completa: project-skeleton/.env.example
# USE_CODEX="Quando precisar gerar imagens"
# USE_ANTIGRAVITY="Quando for fazer deep research na internet"
# USE_GEMINI="Quando o contexto for gigante (1M tokens)"
# USE_HERMES="Quando precisar interagir com o usuário via mensageria"
