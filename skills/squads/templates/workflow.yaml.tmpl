# Workflow Definition — generated by Squad Protocol Engine v4.0.0
# Source of truth: SQUAD_PROTOCOL.md Section 7

workflow:
  id: "{{workflow-id}}"
  name: "{{Workflow Name}}"
  version: "1.0.0"
  description: "{{DESCRIPTION}}"
  type: pipeline  # pipeline | parallel | conditional | dag

triggers:
  - command: "*{{trigger-command}}"
  - event: "{{event_name}}"

config:
  timeout_minutes: 30
  max_retries: 3
  execution_mode: interactive  # yolo | interactive | preflight

sequence:
  - id: step-1
    name: "{{Step 1 Name}}"
    agent: "{{agent-id-1}}"
    task: "{{task-name-1}}.md"
    phase: planning  # planning | implementation | verification
    inputs:
      context: "$trigger.context"
    outputs:
      result: "step-1-output"
    self_verify:
      enabled: true
      checklist:
        - "Output contains required fields"
        - "No placeholder values remain"
    on_success: continue
    on_failure: retry

  - id: step-2
    name: "{{Step 2 Name}}"
    agent: "{{agent-id-2}}"
    task: "{{task-name-2}}.md"
    phase: implementation
    depends_on: [step-1]  # for DAG workflows
    inputs:
      previous: "$steps.step-1.result"
    outputs:
      result: "step-2-output"
    self_verify:
      enabled: true
      checklist:
        - "Implementation matches spec"
    on_success: continue
    on_failure: escalate

  - id: step-3
    name: "{{Step 3 Name}}"
    agent: "{{agent-id-3}}"
    task: "{{task-name-3}}.md"
    phase: verification
    depends_on: [step-2]
    inputs:
      to_review: "$steps.step-2.result"
    outputs:
      verdict: "step-3-verdict"
    on_success: complete
    on_failure: retry

gates:
  - after: step-1
    type: quality  # quality | human | automated
    criteria:
      min_score: 7.0
  - after: step-2
    type: human
    prompt: "Review implementation before QA?"

success_indicators:
  - "All steps completed successfully"
  - "Final verdict is PASS or APPROVE"
  - "No blocking errors in traces"

error_handlers:
  - error: timeout
    action: escalate
  - error: max_retries
    action: escalate
  - error: blocked
    action: halt
